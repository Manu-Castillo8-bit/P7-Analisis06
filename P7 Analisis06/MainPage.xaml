<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="P7_Analisis06.MainPage">


    <StackLayout Padding="30" Spacing="20" VerticalOptions="Center">

        <!-- Imagen de perfil -->
        <Image Source="foto_perfil.png" 
               HeightRequest="150" WidthRequest="150"
               HorizontalOptions="Center" Aspect="AspectFill"/>

        <!-- Label para el nombre completo -->
        <Label x:Name="NombreCompletoLabel" 
               Text="Tu Nombre Completo" 
               HorizontalOptions="Center" 
               FontSize="24" FontAttributes="Bold"/>

        <!-- Primer Entry -->
        <Entry x:Name="NombreEntry" 
               Placeholder="Ingresa tu nombre"/>

        <!-- Segundo Entry -->
        <Entry x:Name="ApellidoEntry" 
               Placeholder="Ingresa tu apellido"
               ReturnType="Done"/>

        <!-- Botón para actualizar el Label -->
        <Button Text="Actualizar Nombre" 
                Clicked="OnActualizarClicked"/>

    </StackLayout>
</ContentPage>
